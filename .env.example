ADMIN_PORT=9000
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# Required for docker compose startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

LETSENCRYPT_EMAIL=admin@example.com

# Optional pseudo-cluster runtime identity.
# Start multiple FlowProxy instances with shared config files and different NODE_ID values.
# NODE_ID=default
# NODE_NAME=Default Node

# Optional pull-based control plane sync for follower nodes.
# When set, the instance becomes read-only for sites/settings/nodes writes
# and periodically pulls control data from the specified controller.
# CLUSTER_SYNC_URL=https://10.0.0.16:19443
# CLUSTER_SYNC_URLS=https://10.0.0.16:19443,https://10.0.0.11:19443,https://10.0.0.19:19443
# CLUSTER_SYNC_USERNAME=admin
# CLUSTER_SYNC_PASSWORD=change-me-strong-password
# CLUSTER_SYNC_INTERVAL=3s

# Optional storage backend for control data.
# STORAGE_BACKEND=file
# STORAGE_ETCD_ENDPOINTS=http://127.0.0.1:2379
# STORAGE_ETCD_PREFIX=/flowproxy
# STORAGE_ETCD_DIAL_TIMEOUT=3s
